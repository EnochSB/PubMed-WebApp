# 이 파일을 `.streamlit/secrets.toml`로 복사한 뒤 실제 값을 입력하세요.
# 실제 Client Secret과 cookie_secret은 Git에 커밋하지 않습니다.

[auth]
redirect_uri = "http://localhost:8501/oauth2callback"
cookie_secret = "충분히-길고-무작위인-비밀값으로-교체"

[auth.google]
client_id = "Google-Cloud-Console에서-발급한-클라이언트-ID"
client_secret = "Google-Cloud-Console에서-발급한-클라이언트-보안-비밀"
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"
